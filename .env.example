# Local mode uses SQLite automatically. Docker mode uses these values.
DATABASE_URL=sqlite:///data/incident_commander.db
SQLITE_PATH=data/incident_commander.db
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
ENABLE_NEO4J=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=incidentcommander
ENABLE_OPENSEARCH=false
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_SSL=false
